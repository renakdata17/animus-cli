{
  "schema": "ao.state-machines.v1",
  "version": 1,
  "workflow": {
    "initial_state": "idle",
    "terminal_states": [
      "completed",
      "failed",
      "cancelled"
    ],
    "transitions": [
      {
        "from": "idle",
        "event": "start",
        "to": "evaluate-transition"
      },
      {
        "from": "idle",
        "event": "pause-requested",
        "to": "paused"
      },
      {
        "from": "idle",
        "event": "cancel-requested",
        "to": "cancelled"
      },
      {
        "from": "evaluate-transition",
        "event": "phase-started",
        "to": "run-phase"
      },
      {
        "from": "evaluate-transition",
        "event": "no-more-phases",
        "to": "completed"
      },
      {
        "from": "evaluate-transition",
        "event": "pause-requested",
        "to": "paused"
      },
      {
        "from": "evaluate-transition",
        "event": "cancel-requested",
        "to": "cancelled"
      },
      {
        "from": "evaluate-transition",
        "event": "rework-budget-exceeded",
        "to": "failed"
      },
      {
        "from": "run-phase",
        "event": "phase-succeeded",
        "to": "evaluate-gates"
      },
      {
        "from": "run-phase",
        "event": "phase-failed",
        "to": "evaluate-gates"
      },
      {
        "from": "run-phase",
        "event": "pause-requested",
        "to": "paused"
      },
      {
        "from": "run-phase",
        "event": "cancel-requested",
        "to": "cancelled"
      },
      {
        "from": "evaluate-gates",
        "event": "gates-passed",
        "to": "apply-transition"
      },
      {
        "from": "evaluate-gates",
        "event": "gates-failed",
        "to": "apply-transition"
      },
      {
        "from": "evaluate-gates",
        "event": "policy-decision-ready",
        "to": "apply-transition"
      },
      {
        "from": "evaluate-gates",
        "event": "policy-decision-failed",
        "to": "apply-transition"
      },
      {
        "from": "evaluate-gates",
        "event": "pause-requested",
        "to": "paused"
      },
      {
        "from": "evaluate-gates",
        "event": "cancel-requested",
        "to": "cancelled"
      },
      {
        "from": "evaluate-gates",
        "event": "rework-budget-exceeded",
        "to": "failed"
      },
      {
        "from": "apply-transition",
        "event": "start",
        "to": "evaluate-transition"
      },
      {
        "from": "apply-transition",
        "event": "no-more-phases",
        "to": "completed"
      },
      {
        "from": "apply-transition",
        "event": "phase-started",
        "to": "run-phase"
      },
      {
        "from": "apply-transition",
        "event": "pause-requested",
        "to": "paused"
      },
      {
        "from": "apply-transition",
        "event": "cancel-requested",
        "to": "cancelled"
      },
      {
        "from": "apply-transition",
        "event": "rework-budget-exceeded",
        "to": "failed"
      },
      {
        "from": "paused",
        "event": "resume-requested",
        "to": "evaluate-transition"
      },
      {
        "from": "paused",
        "event": "cancel-requested",
        "to": "cancelled"
      },
      {
        "from": "failed",
        "event": "resume-requested",
        "to": "evaluate-transition"
      },
      {
        "from": "failed",
        "event": "cancel-requested",
        "to": "cancelled"
      }
    ],
    "guards": [
      {
        "id": "rework_budget_available"
      }
    ],
    "actions": [
      {
        "id": "append_decision_record"
      },
      {
        "id": "set_workflow_status_from_state"
      }
    ]
  },
  "requirements_lifecycle": {
    "initial_state": "draft",
    "terminal_states": [
      "approved",
      "deprecated",
      "implemented",
      "done"
    ],
    "policy": {
      "max_rework_rounds": 3
    },
    "transitions": [
      {
        "from": "draft",
        "event": "refine",
        "to": "refined",
        "action": "add_refine_comment"
      },
      {
        "from": "refined",
        "event": "refine",
        "to": "refined",
        "action": "add_refine_comment"
      },
      {
        "from": "po-review",
        "event": "refine",
        "to": "refined",
        "action": "add_refine_comment"
      },
      {
        "from": "em-review",
        "event": "refine",
        "to": "refined",
        "action": "add_refine_comment"
      },
      {
        "from": "needs-rework",
        "event": "refine",
        "to": "refined",
        "action": "add_refine_comment"
      },
      {
        "from": "refined",
        "event": "po-pass",
        "to": "po-review"
      },
      {
        "from": "po-review",
        "event": "po-pass",
        "to": "em-review",
        "action": "add_po_approval_comment"
      },
      {
        "from": "po-review",
        "event": "po-fail",
        "to": "needs-rework",
        "guard": "rework_budget_available",
        "action": "add_rework_comment"
      },
      {
        "from": "em-review",
        "event": "em-pass",
        "to": "approved",
        "action": "add_em_approval_comment"
      },
      {
        "from": "em-review",
        "event": "em-fail",
        "to": "needs-rework",
        "guard": "rework_budget_available",
        "action": "add_rework_comment"
      }
    ],
    "guards": [
      {
        "id": "rework_budget_available"
      }
    ],
    "actions": [
      {
        "id": "add_refine_comment"
      },
      {
        "id": "add_po_approval_comment"
      },
      {
        "id": "add_em_approval_comment"
      },
      {
        "id": "add_rework_comment"
      }
    ],
    "comment_templates": {
      "approved": "Requirement approved for task materialization and workflow execution.",
      "em_approved": "EM review approved implementation readiness and quality gates.",
      "po_approved": "PO review approved requirement scope and outcome alignment.",
      "refine": "Requirement refined and prepared for PO/EM review pipeline."
    }
  }
}