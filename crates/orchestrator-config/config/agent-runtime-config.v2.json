      "output_contract": null,
      "output_json_schema": null,
      "command": null,
      "manual": null
    },
    "implementation": {
      "mode": "agent",
      "agent_id": "swe",
      "directive": "Implement production-quality code for this task. Keep changes focused and executable.",
      "runtime": null,
      "capabilities": {
        "writes_files": true,
        "requires_commit": true,
        "enforce_product_changes": true
      },
      "output_contract": {
        "kind": "implementation_result",
        "required_fields": [
          "commit_message"
        ]
      },
      "output_json_schema": {
        "type": "object",
        "required": [
          "kind",
          "commit_message"
        ],
        "properties": {
          "kind": {
            "const": "implementation_result"
          },
          "commit_message": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      },
      "decision_contract": {
        "required_evidence": ["files_modified"],
        "min_confidence": 0.7,
        "max_risk": "medium",
        "allow_missing_decision": true
      },
      "command": null,
      "manual": null
    }
