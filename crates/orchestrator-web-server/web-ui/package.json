{
  "name": "orchestrator-web-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run check:performance-budgets",
    "preview": "vite preview",
    "check:performance-budgets": "node scripts/check-performance-budgets.mjs",
    "codegen": "graphql-codegen --config codegen.ts",
    "test": "vitest run",
    "test:e2e:smoke": "node ./scripts/smoke-e2e.mjs",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/sora": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "graphql-ws": "^6.0.7",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7.13.0",
    "shadcn": "^4.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@testing-library/react": "16.3.0",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@vitejs/plugin-react": "4.4.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "26.1.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.57.0",
    "vite": "6.3.5",
    "vitest": "3.2.4"
  }
}
